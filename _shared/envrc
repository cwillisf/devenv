export DIRENV_WARN_TIMEOUT=20s

devenv_args=()

devenv_project_dir="$(pwd)"

watch_file "${devenv_project_dir}/.nvmrc"
if [[ -r "${devenv_project_dir}/.nvmrc" ]]; then
  devenv_args+=("--option" "devenv-override.node-major:string" "$(sed -E 's/v?([0-9]+).*/\1/' < "$devenv_project_dir/.nvmrc")")
fi

# Find the config-specific dir by following the project .envrc symlink exactly
# one level. This is robust against the case where devenv.yaml is already
# symlinked into the project dir (which would fool a devenv.yaml-existence check).
if _envrc_target="$(readlink -- "${BASH_SOURCE[0]}" 2>/dev/null)"; then
  devenv_config_dir="$(cd -- "$(dirname -- "$_envrc_target")" &> /dev/null && pwd)"
else
  devenv_config_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
fi
unset _envrc_target

if [[ ! -f "$devenv_config_dir/devenv.yaml" ]]; then
  echo "devenv.yaml not found in $devenv_config_dir"
  false
fi

if [[ "$devenv_project_dir" != "$devenv_config_dir" ]]; then
  # Symlink config files into the project dir so devenv runs from here.
  # This ensures all CWD-sensitive operations (enterShell scripts, git hooks,
  # DEVENV_ROOT, etc.) use the project dir rather than the config dir.
  for f in devenv.yaml devenv.nix; do
    [[ -e "$devenv_config_dir/$f" ]] || continue
    if [[ "$(readlink -- "$f" 2>/dev/null)" != "$devenv_config_dir/$f" ]]; then
      ln -sf "$devenv_config_dir/$f" "$f"
    fi
  done

  # Resolve all symlinks to find the real envrc, which lives in _shared/ —
  # exactly the directory the 'shared' input should point to.
  shared_dir="$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")"

  # Copy devenv.lock rather than symlinking it. devenv overwrites the lock with
  # machine-specific absolute paths when the 'shared' input is resolved via
  # --override-input below; a copy keeps the config dir's lock clean with
  # relative paths. The copy is refreshed whenever the config dir's lock is
  # newer (i.e. after a `devenv update` run from the config dir).
  #
  # Substitute the absolute path for the 'shared' input so Nix resolves it
  # correctly from the project dir on subsequent activations (when devenv's
  # 'Updating inputs' step runs before --override-input can intercept it).
  if [[ ! -f "devenv.lock" ]] || [[ "$devenv_config_dir/devenv.lock" -nt "devenv.lock" ]]; then
    if command -v jq &>/dev/null && jq -e '.nodes.shared' "$devenv_config_dir/devenv.lock" &>/dev/null; then
      jq --arg p "$shared_dir" \
        '.nodes.shared.locked.path = $p | .nodes.shared.original.path = $p' \
        "$devenv_config_dir/devenv.lock" > devenv.lock
    else
      cp "$devenv_config_dir/devenv.lock" devenv.lock
    fi
  fi

  # Override the 'shared' input with an absolute path so Nix doesn't try to
  # resolve the relative path: URL in devenv.yaml from the project dir.
  devenv_args+=("--override-input" "shared" "path:$shared_dir")

  # Share .devenv/ with the config dir so multiple projects using the same
  # config share the Nix profile and avoid redundant builds.
  # Ensure the target exists first so the symlink is never broken.
  mkdir -p "$devenv_config_dir/.devenv"
  if [[ -d ".devenv" && ! -L ".devenv" ]]; then
    echo "error: .devenv exists as a real directory in $devenv_project_dir" \
         "(expected a symlink to $devenv_config_dir/.devenv)." \
         "Remove it and re-enter the shell."
    false
  fi
  if [[ "$(readlink -- ".devenv" 2>/dev/null)" != "$devenv_config_dir/.devenv" ]]; then
    ln -sf "$devenv_config_dir/.devenv" .devenv
  fi
fi

# Remove broken symlinks at the top of this directory whose target is in
# /nix/store. These are devenv-generated files (.mcp.json, .lsp.json, etc.)
# whose target derivation has been garbage-collected; `use devenv` below
# regenerates them. The /nix/store filter ensures we never touch a broken
# symlink the user created intentionally.
shopt -s nullglob dotglob
for f in *; do
  [[ -L "$f" && ! -e "$f" ]] || continue
  _target=$(readlink -- "$f")
  if [[ "$_target" == /nix/store/* ]]; then
    echo "envrc: removing broken symlink $f -> $_target (GC'd; will be regenerated)"
    rm -- "$f"
  fi
done
unset _target

eval "$(devenv direnvrc)"
use devenv "${devenv_args[@]}"
