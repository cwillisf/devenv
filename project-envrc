#!/usr/bin/env bash
# The shebang is just for syntax highlighting
# This file is meant to be sourced from your project's .envrc
# Like:
# . ~/path/to/envrc path/to/project-root name-of-env
# For example:
# . ~/devenv/envrc "$PWD" scratch3
set -euo pipefail

project_root_dir="${1}"
if [ -z "${project_root_dir}" ]; then
  project_root_dir="${PWD}"
fi
if [ ! -d "${project_root_dir}" ]; then
  echo "The first argument must be a directory" >&2
  exit 1
fi

name_of_env="${2:-}"
# if [ -z "${name_of_env}" ]; then
#   echo "The second argument must be the name of the environment in the flake" >&2
#   exit 1
# fi

flake_root_dir="$(cd -- "$(dirname -- "$(realpath -- "${BASH_SOURCE[0]}")")" &> /dev/null && pwd)"
if [ ! -f "${flake_root_dir}/flake.nix" ]; then
  echo "The flake.nix file was not found in ${flake_root_dir}" >&2
  exit 1
fi

# The rest of this file is patterned after .envrc, which was generated by devenv
# Please update this file to match any changes in .envrc
# The most important changes from the default .envrc are:
# - add this file to the watch list
# - add "${flake_root_dir}" to the watch path for flake.{nix,lock}
# - put "${project_root_dir}" instead of "$PWD" in the DEVENV_ROOT_FILE
# - add "${flake_root_dir}" to the `use flake` command

if ! has nix_direnv_version || ! nix_direnv_version 3.0.6; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.6/direnvrc" "sha256-RYcUJaRMf8oF5LznDrlCXbkOQrywm0HDv1VjYGaJGdM="
fi

watch_file "${BASH_SOURCE[0]}"
watch_file "${flake_root_dir}/flake.nix"
watch_file "${flake_root_dir}/flake.lock"

DEVENV_ROOT_FILE="$(mktemp)"
printf %s "${project_root_dir}" > "$DEVENV_ROOT_FILE"
if ! use flake "${flake_root_dir}${name_of_env:+#${name_of_env}}" --override-input devenv-root "file+file://$DEVENV_ROOT_FILE"
then
  echo "devenv could not be built. The devenv environment was not loaded." >&2
fi
